# Copy these into your Vercel project's Environment Variables (Production + Preview).
# Never commit real values.

# --- Supabase (from your new dedicated project: Settings > API) ---
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...        # service_role secret — server-side ONLY, never expose

# --- Anthropic (https://console.anthropic.com > API Keys) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Dashboard password (you choose this; used to open dashboard.html) ---
DASHBOARD_PASSWORD=change-me-to-something-strong

# ============================================================================
# OPTIONAL third-party verification. Leave unset and the site works exactly
# as before — the verification steps only appear once these are configured.
# See README.md > "Finishing the Vouched & Plaid setup".
# ============================================================================

# --- Vouched ID verification (https://app.vouched.id > Keys) ---
# Public key drives the in-browser capture flow; private key lets the server
# pull the verification result. Set BOTH.
VOUCHED_PUBLIC_KEY=
VOUCHED_PRIVATE_KEY=

# --- Plaid bank verification (https://dashboard.plaid.com > Developers > Keys) ---
# PLAID_ENV is "sandbox" or "production" (start with sandbox; switch to
# production once approved by Plaid, using the production secret).
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# --- Stripe Identity ID verification (https://dashboard.stripe.com > Developers > API keys) ---
# Publishable key drives the in-browser verification modal; the secret key
# retrieves the result server-side. Set BOTH. Start with the TEST keys
# (pk_test_… / sk_test_…), then switch to live keys when you're ready.
# Enable Identity first at https://dashboard.stripe.com/identity.
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
