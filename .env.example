# Copy these into your Vercel project's Environment Variables (Production + Preview).
# Never commit real values.

# --- Supabase (from your new dedicated project: Settings > API) ---
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...        # service_role secret — server-side ONLY, never expose

# --- Anthropic (https://console.anthropic.com > API Keys) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Dashboard password (you choose this; used to open dashboard.html) ---
DASHBOARD_PASSWORD=change-me-to-something-strong
